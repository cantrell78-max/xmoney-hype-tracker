# xAI Grok API — https://console.x.ai/
XAI_API_KEY=

# Optional Grok settings
XAI_MODEL=grok-3-mini
XAI_BASE_URL=https://api.x.ai/v1

# X (Twitter) API v2 Bearer Token (App-only) — https://developer.x.com/
# Required for live posts. Leave empty to use bundled demo data.
X_BEARER_TOKEN=

# Search window (hours) and max posts to fetch
SEARCH_HOURS=48
MAX_POSTS=50