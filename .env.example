# xAI Grok API — https://console.x.ai/
XAI_API_KEY=

# Optional Grok settings
XAI_MODEL=grok-3-mini
XAI_BASE_URL=https://api.x.ai/v1

# X (Twitter) API v2 — https://developer.x.com/
# Leave empty to use bundled demo posts (good for livestreams)
X_BEARER_TOKEN=

# Search window (hours) and max posts to fetch
SEARCH_HOURS=48
MAX_POSTS=50